@using System.Globalization
@using System.Text.Json
@model StockDetailsViewModel
@{
    ViewData["Title"] = $"{Model.ShortSymbol} Analizi";
    var displayCulture = CultureInfo.GetCultureInfo("tr-TR");
    var historyUrl = Url.Action("History", "Stocks", new { symbol = Model.Stock.Symbol });
    var indicatorsUrl = Url.Action("Indicators", "Stocks", new { symbol = Model.Stock.Symbol });
    var aiCommentUrl = Url.Action("AiComment", "Stocks", new { symbol = Model.Stock.Symbol });
    var symbolJson = JsonSerializer.Serialize(Model.Stock.Symbol);
    var tvSymbolJson = JsonSerializer.Serialize(Model.Stock.TvSymbol);
    var historyUrlJson = JsonSerializer.Serialize(historyUrl);
    var indicatorsUrlJson = JsonSerializer.Serialize(indicatorsUrl);
    var aiCommentUrlJson = JsonSerializer.Serialize(aiCommentUrl);
}

<nav aria-label="İçerik yolu" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Index">Hisseler</a></li>
        <li class="breadcrumb-item active" aria-current="page">@Model.ShortSymbol</li>
    </ol>
</nav>

@if (User.Identity?.IsAuthenticated == true)
{
    <form class="d-none" data-watchlist-form data-endpoint="@Url.Action("ToggleWatchlist", "Stocks")">
        @Html.AntiForgeryToken()
    </form>
}
<div id="watchlistStatus" class="visually-hidden" aria-live="polite"></div>

<section class="stock-detail-hero mb-4" aria-labelledby="stockTitle">
    <div class="stock-detail-main">
        <div class="d-flex flex-wrap align-items-center gap-2 mb-3">
            <span class="market-badge">@(Model.Stock.Market == "BIST" ? "BIST" : "ABD")</span>
            <a class="sector-badge"
               asp-action="Index"
               asp-route-list="@(Model.Stock.Market == "BIST" ? "xu500" : "us")"
               asp-route-sector="@Model.Stock.Sector">@Model.Stock.Sector</a>
            <span class="stock-code-badge">@Model.ShortSymbol</span>
            <span class="data-delay-note"><i class="bi bi-clock-history" aria-hidden="true"></i> Veriler gecikmeli olabilir</span>
        </div>
        <h1 id="stockTitle" class="mb-2">@Model.Stock.Name</h1>
        <p class="text-muted mb-0">@(Model.Stock.Market == "BIST" ? "Borsa İstanbul" : "ABD piyasaları") · Güncel fiyat ve teknik görünüm</p>
    </div>
    <div class="stock-quote-panel">
        @if (Model.Quote is not null)
        {
            <div class="stock-price-display">@Model.CurrencySymbol@Model.Quote.Price.ToString("N2", displayCulture)</div>
            @if (Model.Quote.ChangePercent is decimal changePercent)
            {
                var changeClass = changePercent > 0 ? "gain" : changePercent < 0 ? "loss" : "neutral";
                var sign = changePercent > 0 ? "+" : string.Empty;
                var changeIcon = changePercent > 0 ? "bi-caret-up-fill" : changePercent < 0 ? "bi-caret-down-fill" : "bi-dash";
                <div class="d-flex flex-wrap justify-content-lg-end align-items-center gap-2 mt-2">
                    <span class="change-pill stock-change-pill @changeClass">
                        <i class="bi @changeIcon" aria-hidden="true"></i>
                        @if (Model.Quote.Change is decimal change)
                        {
                            <span>@sign@Model.CurrencySymbol@change.ToString("N2", displayCulture)</span>
                        }
                        <span>(@sign@changePercent.ToString("N2", displayCulture)%)</span>
                    </span>
                    <span class="small text-muted">bugün</span>
                </div>
            }
        }
        else
        {
            <div class="fs-5 text-muted">Fiyat verisi alınamadı</div>
        }
        <div class="d-flex flex-wrap justify-content-lg-end gap-2 mt-3">
            @if (User.Identity?.IsAuthenticated == true)
            {
                <button type="button"
                        class="btn btn-outline-primary watchlist-toggle"
                        data-watchlist-toggle
                        data-symbol="@Model.Stock.Symbol"
                        data-watchlisted="@Model.IsWatched.ToString().ToLowerInvariant()"
                        aria-pressed="@Model.IsWatched.ToString().ToLowerInvariant()">
                    <i class="bi @(Model.IsWatched ? "bi-star-fill" : "bi-star")" aria-hidden="true"></i>
                    <span>@(Model.IsWatched ? "Takipten çıkar" : "Takibe ekle")</span>
                </button>
            }
            else
            {
                <a class="btn btn-outline-primary"
                   asp-area="Identity"
                   asp-page="/Account/Login"
                   asp-route-returnUrl="@Context.Request.Path">
                    <i class="bi bi-star" aria-hidden="true"></i>
                    Takip için giriş yap
                </a>
            }
            <a class="btn btn-primary stock-trade-button" asp-controller="Portfolio" asp-action="Trade" asp-route-symbol="@Model.Stock.Symbol">
                <i class="bi bi-plus-circle" aria-hidden="true"></i>
                Portföye ekle
            </a>
        </div>
    </div>
</section>

<div class="row g-3 indicator-summary-grid mb-4" aria-label="Teknik gösterge özeti">
    <div class="col-sm-6 col-xl-3">
        <div class="card indicator-summary-card h-100">
            <div class="card-body">
                <div class="indicator-card-label"><i class="bi bi-graph-up-arrow" aria-hidden="true"></i> Kısa vadeli eğilim</div>
                <div id="summaryTrend" class="indicator-card-value">Yükleniyor...</div>
                <div id="summaryAverages" class="small text-muted mt-1">SMA değerleri bekleniyor</div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card indicator-summary-card h-100">
            <div class="card-body">
                <div class="indicator-card-label"><i class="bi bi-speedometer2" aria-hidden="true"></i> RSI (14)</div>
                <div id="summaryRsi" class="indicator-card-value">Yükleniyor...</div>
                <div id="summaryRsiSignal" class="small text-muted mt-1">-</div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card indicator-summary-card h-100">
            <div class="card-body">
                <div class="indicator-card-label"><i class="bi bi-activity" aria-hidden="true"></i> MACD (12, 26, 9)</div>
                <div id="summaryMacd" class="indicator-card-value">Yükleniyor...</div>
                <div id="summaryMacdSignal" class="small text-muted mt-1">-</div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card indicator-summary-card h-100">
            <div class="card-body">
                <div class="indicator-card-label"><i class="bi bi-bounding-box-circles" aria-hidden="true"></i> Bollinger (20, 2)</div>
                <div id="summaryBollinger" class="indicator-card-value indicator-card-value-compact">Yükleniyor...</div>
                <div class="small text-muted mt-1">Alt / Orta / Üst bant</div>
            </div>
        </div>
    </div>
</div>

<section class="card analysis-section mb-4" aria-labelledby="ownChartHeading">
    <div class="card-body">
        <div class="analysis-section-header d-flex flex-column flex-xl-row justify-content-between gap-3 mb-3">
            <div>
                <h2 id="ownChartHeading" class="h4 mb-1">Fiyat ve teknik göstergeler</h2>
                <p class="text-muted small mb-0">Mum ve hacim verileri Yahoo Finance üzerinden sağlanır.</p>
            </div>
            <div class="d-flex flex-wrap align-items-center gap-2">
                <div class="btn-group btn-group-sm" role="group" aria-label="Grafik tarih aralığı">
                    <button type="button" class="btn btn-outline-primary" data-range="1mo">1A</button>
                    <button type="button" class="btn btn-outline-primary" data-range="3mo">3A</button>
                    <button type="button" class="btn btn-primary" data-range="1y">1Y</button>
                    <button type="button" class="btn btn-outline-primary" data-range="5y">5Y</button>
                </div>
                <div class="form-check form-switch ms-2">
                    <input class="form-check-input" type="checkbox" role="switch" id="toggleSma" data-overlay="sma" checked />
                    <label class="form-check-label" for="toggleSma">SMA</label>
                </div>
                <div class="form-check form-switch">
                    <input class="form-check-input" type="checkbox" role="switch" id="toggleEma" data-overlay="ema" checked />
                    <label class="form-check-label" for="toggleEma">EMA</label>
                </div>
                <div class="form-check form-switch">
                    <input class="form-check-input" type="checkbox" role="switch" id="toggleBollinger" data-overlay="bollinger" checked />
                    <label class="form-check-label" for="toggleBollinger">Bollinger</label>
                </div>
            </div>
        </div>

        <div id="chartLoading" class="text-center text-muted py-3">Grafik verileri yükleniyor...</div>
        <div id="chartError" class="alert alert-warning d-none" role="alert"></div>
        <div id="priceChart" class="chart-container" aria-label="Mum ve hacim grafiği"></div>
        <h3 class="h6 mt-4 mb-2">RSI (14)</h3>
        <div id="rsiChart" class="indicator-chart-container" aria-label="RSI grafiği"></div>
        <h3 class="h6 mt-4 mb-2">MACD (12, 26, 9)</h3>
        <div id="macdChart" class="indicator-chart-container" aria-label="MACD grafiği"></div>
    </div>
</section>

<section class="card analysis-section ai-analysis-section mb-4" aria-labelledby="aiCommentaryHeading">
    <div class="card-body">
        <div class="analysis-section-header d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
            <div>
                <h2 id="aiCommentaryHeading" class="h4 mb-1">AI grafik yorumu</h2>
                <p class="text-muted small mb-0">Son fiyat hareketleri ve teknik göstergeler Gemini ile Türkçe olarak yorumlanır.</p>
            </div>
            @if (User.Identity?.IsAuthenticated == true)
            {
                <form id="aiCommentaryForm" class="flex-shrink-0">
                    @Html.AntiForgeryToken()
                    <button id="aiCommentaryButton" type="submit" class="btn btn-primary">
                        <span id="aiCommentarySpinner" class="spinner-border spinner-border-sm me-2 d-none" aria-hidden="true"></span>
                        <span id="aiCommentaryButtonText">AI Yorumu Al</span>
                    </button>
                </form>
            }
            else
            {
                <a class="btn btn-outline-primary flex-shrink-0"
                   asp-area="Identity"
                   asp-page="/Account/Login"
                   asp-route-returnUrl="@Context.Request.Path">Yorum için giriş yap</a>
            }
        </div>
        <p id="aiCommentaryMeta" class="small text-muted mt-4 mb-0 d-none"></p>
        <div id="aiCommentaryResult" class="ai-commentary mt-4 d-none" aria-live="polite"></div>
        <p class="small text-muted mb-0 mt-3">AI çıktıları hatalı olabilir; yatırım kararlarınızı bağımsız kaynaklarla doğrulayın.</p>
    </div>
</section>

<section class="mb-4" aria-labelledby="tradingViewHeading">
    <div class="analysis-section-header mb-3">
        <h2 id="tradingViewHeading" class="h4 mb-1">TradingView analizleri</h2>
        <p class="text-muted small mb-0">İnternet üzerinden sağlanan gelişmiş grafik ve teknik analiz özeti.</p>
    </div>
    <div class="row g-4">
        @if (Model.Stock.Market == "BIST")
        {
            <div class="col-xl-8">
                <div class="alert alert-info h-100 mb-0 d-flex align-items-center gap-3" role="note">
                    <i class="bi bi-info-circle fs-4 flex-shrink-0" aria-hidden="true"></i>
                    <p class="mb-0">TradingView gelişmiş grafik bileşeni BIST sembollerini desteklemediği için gösterilmiyor. Bu hisseyi <a href="#priceChart" class="alert-link">yukarıdaki interaktif fiyat grafiğimizden</a> inceleyebilirsiniz.</p>
                </div>
            </div>
        }
        else
        {
            <div class="col-xl-8">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body p-2 tradingview-panel tradingview-chart-panel">
                        <div class="tradingview-widget-container h-100 w-100">
                            <div class="tradingview-widget-container__widget h-100 w-100"></div>
                            <script type="text/javascript" src="https://s3.tradingview.com/external-embedding/embed-widget-advanced-chart.js" async>
                            {
                                "autosize": true,
                                "symbol": @Html.Raw(tvSymbolJson),
                                "interval": "D",
                                "timezone": "Europe/Istanbul",
                                "theme": "light",
                                "style": "1",
                                "locale": "tr",
                                "allow_symbol_change": false,
                                "hide_side_toolbar": false,
                                "support_host": "https://www.tradingview.com"
                            }
                            </script>
                        </div>
                    </div>
                </div>
            </div>
        }
        <div class="col-xl-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body p-2 tradingview-panel tradingview-analysis-panel">
                    <div class="tradingview-widget-container h-100 w-100">
                        <div class="tradingview-widget-container__widget h-100 w-100"></div>
                        <script type="text/javascript" src="https://s3.tradingview.com/external-embedding/embed-widget-technical-analysis.js" async>
                        {
                            "interval": "1D",
                            "width": "100%",
                            "height": "100%",
                            "isTransparent": true,
                            "symbol": @Html.Raw(tvSymbolJson),
                            "showIntervalTabs": true,
                            "displayMode": "single",
                            "locale": "tr",
                            "colorTheme": "light"
                        }
                        </script>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@if (Model.Stock.Market == "BIST" && Model.KapDisclosures is not null)
{
    <section class="mb-4" aria-labelledby="companyKapHeading">
        <div class="analysis-section-header mb-3">
            <h2 id="companyKapHeading" class="h4 mb-1">Şirket Bildirimleri (KAP)</h2>
            <p class="text-muted small mb-0">Son 14 gündeki resmi şirket açıklamaları.</p>
        </div>

        @if (Model.KapDisclosures.Count == 0)
        {
            <div class="alert alert-light border mb-0">Son 14 günde KAP bildirimi bulunmuyor.</div>
        }
        else
        {
            <div class="kap-news-list">
                @foreach (var disclosure in Model.KapDisclosures.Take(10))
                {
                    <article class="kap-news-item">
                        <div class="kap-news-time">
                            <time datetime="@disclosure.PublishedAt.ToString("O")" title="@disclosure.PublishedAt.ToString("dd.MM.yyyy HH:mm")">
                                @RelativeKapTime(disclosure.PublishedAt)
                            </time>
                            <span>@disclosure.PublishedAt.ToString("HH:mm")</span>
                        </div>
                        <div class="kap-news-content min-w-0">
                            <div class="d-flex flex-wrap align-items-center gap-2 mb-2">
                                <span class="kap-category-badge">@disclosure.Category</span>
                                @if (disclosure.IsBuyback)
                                {
                                    <span class="badge text-bg-primary">Geri Alım</span>
                                }
                            </div>
                            <p class="kap-news-subject mb-0">@disclosure.Subject</p>
                        </div>
                        <a class="kap-source-link" href="@disclosure.SourceUrl" target="_blank" rel="noopener noreferrer" aria-label="KAP bildirimini yeni sekmede aç">
                            KAP <i class="bi bi-box-arrow-up-right" aria-hidden="true"></i>
                        </a>
                    </article>
                }
            </div>
        }
    </section>
}

@functions {
    private static string RelativeKapTime(DateTimeOffset publishedAt)
    {
        var elapsed = DateTimeOffset.UtcNow - publishedAt.ToUniversalTime();
        if (elapsed < TimeSpan.FromMinutes(1)) return "az önce";
        if (elapsed < TimeSpan.FromHours(1)) return $"{Math.Max(1, (int)elapsed.TotalMinutes)} dk önce";
        if (elapsed < TimeSpan.FromDays(1)) return $"{Math.Max(1, (int)elapsed.TotalHours)} sa önce";
        return $"{Math.Max(1, (int)elapsed.TotalDays)} gün önce";
    }
}

@section Scripts {
    <script>
        (() => {
            const symbol = @Html.Raw(symbolJson);
            const historyUrl = @Html.Raw(historyUrlJson);
            const indicatorsUrl = @Html.Raw(indicatorsUrlJson);
            const loading = document.getElementById('chartLoading');
            const error = document.getElementById('chartError');
            const priceContainer = document.getElementById('priceChart');
            const rsiContainer = document.getElementById('rsiChart');
            const macdContainer = document.getElementById('macdChart');

            if (!window.LightweightCharts) {
                loading.classList.add('d-none');
                error.textContent = 'Grafik kütüphanesi yüklenemedi. Lütfen bağlantınızı kontrol edip sayfayı yenileyin.';
                error.classList.remove('d-none');
                return;
            }

            const chartOptions = container => ({
                width: container.clientWidth,
                height: container === priceContainer ? 430 : 190,
                layout: { background: { color: '#ffffff' }, textColor: '#475569' },
                grid: {
                    vertLines: { color: '#eef2f7' },
                    horzLines: { color: '#eef2f7' }
                },
                rightPriceScale: { borderColor: '#dbe3ec' },
                timeScale: { borderColor: '#dbe3ec', timeVisible: false },
                crosshair: { mode: LightweightCharts.CrosshairMode.Normal }
            });

            const priceChart = LightweightCharts.createChart(priceContainer, chartOptions(priceContainer));
            const candleSeries = priceChart.addCandlestickSeries({
                upColor: '#16a34a', downColor: '#dc2626', borderVisible: false,
                wickUpColor: '#16a34a', wickDownColor: '#dc2626'
            });
            const volumeSeries = priceChart.addHistogramSeries({
                priceFormat: { type: 'volume' }, priceScaleId: 'volume'
            });
            priceChart.priceScale('volume').applyOptions({ scaleMargins: { top: 0.8, bottom: 0 } });

            const overlaySeries = {
                sma: [
                    priceChart.addLineSeries({ color: '#2563eb', lineWidth: 2, title: 'SMA 20' }),
                    priceChart.addLineSeries({ color: '#7c3aed', lineWidth: 2, title: 'SMA 50' }),
                    priceChart.addLineSeries({ color: '#475569', lineWidth: 2, title: 'SMA 200' })
                ],
                ema: [
                    priceChart.addLineSeries({ color: '#f59e0b', lineWidth: 1, title: 'EMA 12' }),
                    priceChart.addLineSeries({ color: '#ea580c', lineWidth: 1, title: 'EMA 26' })
                ],
                bollinger: [
                    priceChart.addLineSeries({ color: '#0891b2', lineWidth: 1, lineStyle: 2, title: 'Boll. Üst' }),
                    priceChart.addLineSeries({ color: '#0e7490', lineWidth: 1, title: 'Boll. Orta' }),
                    priceChart.addLineSeries({ color: '#0891b2', lineWidth: 1, lineStyle: 2, title: 'Boll. Alt' })
                ]
            };

            const rsiChart = LightweightCharts.createChart(rsiContainer, chartOptions(rsiContainer));
            const rsiSeries = rsiChart.addLineSeries({ color: '#7c3aed', lineWidth: 2, title: 'RSI 14' });
            rsiSeries.createPriceLine({ price: 70, color: '#dc2626', lineWidth: 1, lineStyle: 2, axisLabelVisible: true, title: '70' });
            rsiSeries.createPriceLine({ price: 30, color: '#16a34a', lineWidth: 1, lineStyle: 2, axisLabelVisible: true, title: '30' });

            const macdChart = LightweightCharts.createChart(macdContainer, chartOptions(macdContainer));
            const macdSeries = macdChart.addLineSeries({ color: '#2563eb', lineWidth: 2, title: 'MACD' });
            const macdSignalSeries = macdChart.addLineSeries({ color: '#f59e0b', lineWidth: 2, title: 'Sinyal' });
            const macdHistogramSeries = macdChart.addHistogramSeries({ priceFormat: { type: 'price' } });

            const toLineData = points => points.map(point => ({ time: point.time, value: point.value }));
            const formatNumber = value => value == null
                ? '-'
                : Number(value).toLocaleString('tr-TR', { minimumFractionDigits: 2, maximumFractionDigits: 2 });

            const setSummary = latest => {
                const trend = latest.sma20 == null || latest.sma50 == null
                    ? 'Yeterli veri yok'
                    : latest.sma20 > latest.sma50 ? 'Kısa vadeli pozitif' : latest.sma20 < latest.sma50 ? 'Kısa vadeli negatif' : 'Yatay';
                document.getElementById('summaryTrend').textContent = trend;
                document.getElementById('summaryAverages').textContent = `SMA20 ${formatNumber(latest.sma20)} · SMA50 ${formatNumber(latest.sma50)}`;
                document.getElementById('summaryRsi').textContent = formatNumber(latest.rsi14);
                document.getElementById('summaryRsiSignal').textContent = latest.rsiSignal;
                document.getElementById('summaryMacd').textContent = formatNumber(latest.macd);
                document.getElementById('summaryMacdSignal').textContent = latest.macdSignal;
                document.getElementById('summaryBollinger').textContent = `${formatNumber(latest.bollingerLower)} / ${formatNumber(latest.bollingerMiddle)} / ${formatNumber(latest.bollingerUpper)}`;
            };

            const loadCharts = async range => {
                loading.classList.remove('d-none');
                error.classList.add('d-none');

                try {
                    const [historyResponse, indicatorsResponse] = await Promise.all([
                        fetch(`${historyUrl}?range=${encodeURIComponent(range)}&interval=1d`),
                        fetch(`${indicatorsUrl}?range=${encodeURIComponent(range)}`)
                    ]);
                    if (!historyResponse.ok || !indicatorsResponse.ok) {
                        throw new Error('Sunucu grafik verisini döndüremedi.');
                    }

                    const [candles, indicators] = await Promise.all([
                        historyResponse.json(), indicatorsResponse.json()
                    ]);
                    if (!candles.length) {
                        throw new Error(`${symbol} için seçilen aralıkta veri bulunamadı.`);
                    }

                    candleSeries.setData(candles.map(candle => ({
                        time: candle.time,
                        open: candle.open,
                        high: candle.high,
                        low: candle.low,
                        close: candle.close
                    })));
                    volumeSeries.setData(candles.map(candle => ({
                        time: candle.time,
                        value: candle.volume,
                        color: candle.close >= candle.open ? 'rgba(22, 163, 74, 0.35)' : 'rgba(220, 38, 38, 0.35)'
                    })));

                    overlaySeries.sma[0].setData(toLineData(indicators.series.sma20));
                    overlaySeries.sma[1].setData(toLineData(indicators.series.sma50));
                    overlaySeries.sma[2].setData(toLineData(indicators.series.sma200));
                    overlaySeries.ema[0].setData(toLineData(indicators.series.ema12));
                    overlaySeries.ema[1].setData(toLineData(indicators.series.ema26));
                    overlaySeries.bollinger[0].setData(indicators.series.bollinger.map(point => ({ time: point.time, value: point.upper })));
                    overlaySeries.bollinger[1].setData(indicators.series.bollinger.map(point => ({ time: point.time, value: point.middle })));
                    overlaySeries.bollinger[2].setData(indicators.series.bollinger.map(point => ({ time: point.time, value: point.lower })));
                    rsiSeries.setData(toLineData(indicators.series.rsi14));
                    macdSeries.setData(indicators.series.macd.map(point => ({ time: point.time, value: point.macd })));
                    macdSignalSeries.setData(indicators.series.macd
                        .filter(point => point.signal != null)
                        .map(point => ({ time: point.time, value: point.signal })));
                    macdHistogramSeries.setData(indicators.series.macd
                        .filter(point => point.histogram != null)
                        .map(point => ({
                            time: point.time,
                            value: point.histogram,
                            color: point.histogram >= 0 ? 'rgba(22, 163, 74, 0.55)' : 'rgba(220, 38, 38, 0.55)'
                        })));

                    setSummary(indicators.latest);
                    priceChart.timeScale().fitContent();
                    rsiChart.timeScale().fitContent();
                    macdChart.timeScale().fitContent();
                } catch (exception) {
                    error.textContent = exception.message || 'Grafik verileri yüklenemedi.';
                    error.classList.remove('d-none');
                } finally {
                    loading.classList.add('d-none');
                }
            };

            document.querySelectorAll('[data-range]').forEach(button => {
                button.addEventListener('click', () => {
                    document.querySelectorAll('[data-range]').forEach(candidate => {
                        const active = candidate === button;
                        candidate.classList.toggle('btn-primary', active);
                        candidate.classList.toggle('btn-outline-primary', !active);
                    });
                    loadCharts(button.dataset.range);
                });
            });

            document.querySelectorAll('[data-overlay]').forEach(toggle => {
                toggle.addEventListener('change', () => {
                    overlaySeries[toggle.dataset.overlay].forEach(series =>
                        series.applyOptions({ visible: toggle.checked }));
                });
            });

            const resizeObserver = new ResizeObserver(entries => {
                entries.forEach(entry => {
                    const width = Math.floor(entry.contentRect.width);
                    if (entry.target === priceContainer) priceChart.applyOptions({ width });
                    if (entry.target === rsiContainer) rsiChart.applyOptions({ width });
                    if (entry.target === macdContainer) macdChart.applyOptions({ width });
                });
            });
            [priceContainer, rsiContainer, macdContainer].forEach(container => resizeObserver.observe(container));

            loadCharts('1y');
        })();

        (() => {
            const form = document.getElementById('aiCommentaryForm');
            if (!form) return;

            const endpoint = @Html.Raw(aiCommentUrlJson);
            const button = document.getElementById('aiCommentaryButton');
            const buttonText = document.getElementById('aiCommentaryButtonText');
            const spinner = document.getElementById('aiCommentarySpinner');
            const meta = document.getElementById('aiCommentaryMeta');
            const result = document.getElementById('aiCommentaryResult');
            const token = form.querySelector('input[name="__RequestVerificationToken"]').value;

            const renderInline = value => value
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/`([^`]+)`/g, '<code>$1</code>')
                .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
                .replace(/\*(.+?)\*/g, '<em>$1</em>');

            const renderMarkdown = markdown => {
                const lines = markdown.replace(/\r/g, '').split('\n');
                let html = '';
                let listOpen = false;
                const closeList = () => {
                    if (listOpen) {
                        html += '</ul>';
                        listOpen = false;
                    }
                };

                lines.forEach(line => {
                    const listItem = line.match(/^\s*[-*]\s+(.+)$/);
                    const heading = line.match(/^\s*#{1,4}\s+(.+)$/);
                    if (listItem) {
                        if (!listOpen) {
                            html += '<ul>';
                            listOpen = true;
                        }
                        html += `<li>${renderInline(listItem[1])}</li>`;
                    } else if (heading) {
                        closeList();
                        html += `<h3 class="h6 mt-3">${renderInline(heading[1])}</h3>`;
                    } else if (line.trim()) {
                        closeList();
                        html += `<p>${renderInline(line.trim())}</p>`;
                    } else {
                        closeList();
                    }
                });
                closeList();
                return html;
            };

            form.addEventListener('submit', async event => {
                event.preventDefault();
                button.disabled = true;
                buttonText.textContent = 'Yorum hazırlanıyor...';
                spinner.classList.remove('d-none');
                meta.classList.add('d-none');
                meta.textContent = '';
                result.className = 'ai-commentary mt-4 alert alert-light border';
                result.textContent = 'Son 60 günlük fiyat hareketi inceleniyor...';

                try {
                    const response = await fetch(endpoint, {
                        method: 'POST',
                        headers: { 'RequestVerificationToken': token }
                    });
                    const payload = await response.json().catch(() => ({}));
                    if (!response.ok) {
                        throw new Error(payload.message || 'AI yorumu alınamadı.');
                    }

                    if (payload.succeeded === false) {
                        result.className = 'ai-commentary mt-4 alert alert-warning';
                        result.innerHTML = renderMarkdown(payload.commentary);
                        return;
                    }

                    const generatedAt = new Date(payload.generatedAt);
                    const timestamp = Number.isNaN(generatedAt.getTime())
                        ? 'zaman bilgisi alınamadı'
                        : generatedAt.toLocaleString('tr-TR', { dateStyle: 'medium', timeStyle: 'short' });
                    meta.textContent = `Son 60 günlük OHLC verisi ve teknik göstergelere göre üretildi · ${timestamp}`;
                    meta.classList.remove('d-none');
                    result.className = 'ai-commentary mt-2 alert alert-light border';
                    result.innerHTML = renderMarkdown(payload.commentary);
                } catch (exception) {
                    meta.classList.add('d-none');
                    result.className = 'ai-commentary mt-4 alert alert-warning';
                    result.textContent = exception.message || 'AI yorumu alınamadı. Lütfen yeniden deneyin.';
                } finally {
                    button.disabled = false;
                    buttonText.textContent = 'AI Yorumu Al';
                    spinner.classList.add('d-none');
                }
            });
        })();
    </script>
}
