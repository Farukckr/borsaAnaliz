@using System.Globalization
@model IReadOnlyList<Portfolio>
@{
    ViewData["Title"] = "Portföylerim";
    var displayCulture = CultureInfo.GetCultureInfo("tr-TR");
}

<div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-center gap-3 mb-4">
    <div>
        <h1 class="mb-1">Portföylerim</h1>
        <p class="text-muted mb-0">Sanal portföylerinizi oluşturun ve piyasa fiyatlarıyla takip edin.</p>
    </div>
    <a class="btn btn-primary" asp-action="Create">Yeni portföy</a>
</div>

@if (TempData["SuccessMessage"] is string successMessage)
{
    <div class="alert alert-success">@successMessage</div>
}

@if (Model.Count == 0)
{
    <div class="card border-0 shadow-sm">
        <div class="card-body text-center py-5">
            <h2 class="h5">Henüz portföyünüz yok</h2>
            <p class="text-muted">100.000 ₺ varsayılan sanal nakitle ilk portföyünüzü oluşturabilirsiniz.</p>
            <a class="btn btn-primary" asp-action="Create">Portföy oluştur</a>
        </div>
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var portfolio in Model)
        {
            <div class="col-md-6 col-xl-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <h2 class="h5">@portfolio.Name</h2>
                        <div class="text-muted small mb-3">@portfolio.CreatedAt.ToLocalTime().ToString("dd MMMM yyyy", displayCulture)</div>
                        <div class="d-flex justify-content-between mb-3">
                            <span>Başlangıç nakdi</span>
                            <strong>₺@portfolio.InitialCash.ToString("N2", displayCulture)</strong>
                        </div>
                        <a class="btn btn-outline-primary w-100" asp-action="Details" asp-route-id="@portfolio.Id">Portföyü görüntüle</a>
                    </div>
                </div>
            </div>
        }
    </div>
}
