@using System.Globalization
@model PortfolioSnapshot
@{
    ViewData["Title"] = Model.Portfolio.Name;
    var displayCulture = CultureInfo.GetCultureInfo("tr-TR");
    var totalClass = Model.TotalProfitLoss > 0 ? "text-success" : Model.TotalProfitLoss < 0 ? "text-danger" : "text-muted";
}

<nav aria-label="İçerik yolu" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Index">Portföylerim</a></li>
        <li class="breadcrumb-item active" aria-current="page">@Model.Portfolio.Name</li>
    </ol>
</nav>

<div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-start gap-3 mb-4">
    <div>
        <h1 class="mb-1">@Model.Portfolio.Name</h1>
        <p class="text-muted mb-0">Sanal portföy · @Model.Portfolio.CreatedAt.ToLocalTime().ToString("dd MMMM yyyy", displayCulture)</p>
    </div>
    <a class="btn btn-primary" asp-action="Trade" asp-route-portfolioId="@Model.Portfolio.Id">Alım / satım yap</a>
</div>

@if (TempData["SuccessMessage"] is string successMessage)
{
    <div class="alert alert-success">@successMessage</div>
}

@if (Model.HasMissingQuotes)
{
    <div class="alert alert-warning">Bazı güncel fiyatlar alınamadı. Bu pozisyonlar toplam değerde ortalama maliyetle gösteriliyor.</div>
}

<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100"><div class="card-body">
            <div class="text-muted small">Kullanılabilir nakit</div>
            <div class="fs-4 fw-semibold">₺@Model.Cash.ToString("N2", displayCulture)</div>
        </div></div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100"><div class="card-body">
            <div class="text-muted small">Toplam değer</div>
            <div class="fs-4 fw-semibold">₺@Model.TotalValue.ToString("N2", displayCulture)</div>
        </div></div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100"><div class="card-body">
            <div class="text-muted small">Toplam kâr / zarar</div>
            <div class="fs-4 fw-semibold @totalClass">₺@Model.TotalProfitLoss.ToString("N2", displayCulture)</div>
            <div class="small @totalClass">%@Model.TotalReturnPercent.ToString("N2", displayCulture)</div>
        </div></div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100"><div class="card-body">
            <div class="text-muted small">Başlangıç nakdi</div>
            <div class="fs-4 fw-semibold">₺@Model.Portfolio.InitialCash.ToString("N2", displayCulture)</div>
        </div></div>
    </div>
</div>

<section class="card border-0 shadow-sm mb-4" aria-labelledby="holdingsHeading">
    <div class="card-header bg-white border-0 pt-4 px-4"><h2 id="holdingsHeading" class="h4 mb-0">Pozisyonlar</h2></div>
    <div class="card-body p-0 pt-3">
        @if (Model.Positions.Count == 0)
        {
            <div class="text-center text-muted px-4 pb-4">Henüz açık pozisyon yok.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light"><tr>
                        <th>Hisse</th><th class="text-end">Miktar</th><th class="text-end">Ort. maliyet</th>
                        <th class="text-end">Güncel fiyat</th><th class="text-end">Değer</th><th class="text-end">K/Z</th>
                    </tr></thead>
                    <tbody>
                    @foreach (var position in Model.Positions)
                    {
                        var positionClass = position.UnrealizedProfitLoss > 0 ? "text-success" : position.UnrealizedProfitLoss < 0 ? "text-danger" : "text-muted";
                        <tr>
                            <td>
                                <a class="fw-semibold text-decoration-none" asp-controller="Stocks" asp-action="Details" asp-route-symbol="@position.Symbol">@position.Symbol</a>
                                <div class="small text-muted">@position.Name</div>
                            </td>
                            <td class="text-end">@position.Quantity.ToString("N4", displayCulture)</td>
                            <td class="text-end">@position.CurrencySymbol@position.AverageCost.ToString("N2", displayCulture)</td>
                            <td class="text-end">@(position.CurrentPrice is decimal price ? $"{position.CurrencySymbol}{price.ToString("N2", displayCulture)}" : "-")</td>
                            <td class="text-end">@position.CurrencySymbol@position.Value.ToString("N2", displayCulture)</td>
                            <td class="text-end @positionClass">
                                @if (position.UnrealizedProfitLoss is decimal profitLoss && position.UnrealizedProfitLossPercent is decimal profitLossPercent)
                                {
                                    <span>@position.CurrencySymbol@profitLoss.ToString("N2", displayCulture) (%@profitLossPercent.ToString("N2", displayCulture))</span>
                                }
                                else
                                {
                                    <span>-</span>
                                }
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </div>
</section>

<section class="card border-0 shadow-sm" aria-labelledby="transactionsHeading">
    <div class="card-header bg-white border-0 pt-4 px-4"><h2 id="transactionsHeading" class="h4 mb-0">İşlem geçmişi</h2></div>
    <div class="card-body p-0 pt-3">
        @if (Model.Transactions.Count == 0)
        {
            <div class="text-center text-muted px-4 pb-4">Henüz işlem yok.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead class="table-light"><tr><th>Tarih</th><th>Hisse</th><th>İşlem</th><th class="text-end">Miktar</th><th class="text-end">Fiyat</th><th class="text-end">Tutar</th></tr></thead>
                    <tbody>
                    @foreach (var transaction in Model.Transactions)
                    {
                        <tr>
                            <td>@transaction.ExecutedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm", displayCulture)</td>
                            <td><span class="fw-semibold">@transaction.Symbol</span><div class="small text-muted">@transaction.Name</div></td>
                            <td><span class="badge @(transaction.Type == TransactionType.Buy ? "text-bg-success" : "text-bg-danger")">@(transaction.Type == TransactionType.Buy ? "Alım" : "Satım")</span></td>
                            <td class="text-end">@transaction.Quantity.ToString("N4", displayCulture)</td>
                            <td class="text-end">@transaction.CurrencySymbol@transaction.Price.ToString("N2", displayCulture)</td>
                            <td class="text-end">@transaction.CurrencySymbol@((transaction.Quantity * transaction.Price).ToString("N2", displayCulture))</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </div>
</section>
