@model ErrorViewModel
@{
    ViewData["Title"] = "Bir sorun oluştu";
}

<section class="content-panel text-center py-5">
    <span class="content-panel-icon text-danger bg-danger-subtle" aria-hidden="true"><i class="bi bi-exclamation-triangle-fill"></i></span>
    <div class="section-kicker">İşlem tamamlanamadı</div>
    <h1 class="h2 mb-3">Beklenmeyen bir sorun oluştu.</h1>
    <p class="text-muted mx-auto mb-4" style="max-width: 35rem;">
        İsteğinizi işlerken geçici bir hata oluştu. Sayfayı yenileyebilir veya güvenli biçimde ana ekrana dönebilirsiniz.
    </p>
    <div class="d-flex flex-column flex-sm-row justify-content-center gap-2">
        <a class="btn btn-primary" asp-controller="Home" asp-action="Index">
            <i class="bi bi-house-door me-1" aria-hidden="true"></i> Ana sayfaya dön
        </a>
        <button class="btn btn-outline-primary" type="button" onclick="window.location.reload()">
            <i class="bi bi-arrow-clockwise me-1" aria-hidden="true"></i> Tekrar dene
        </button>
    </div>
    @if (Model.ShowRequestId)
    {
        <p class="small text-muted mt-4 mb-0">
            Referans kodu: <code>@Model.RequestId</code>
        </p>
    }
</section>
